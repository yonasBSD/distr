{
  "name": "distr.sh",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "copy-changelog": "cat src/content/docs/_changelog-header.md > src/content/docs/changelog.md && tail -n +2 ../CHANGELOG.md >> src/content/docs/changelog.md",
    "predev": "pnpm copy-changelog",
    "prestart": "pnpm copy-changelog",
    "prebuild": "pnpm copy-changelog",
    "precheck": "pnpm copy-changelog",
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "lint": "prettier --check .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@astrojs/mdx": "6.0.2",
    "@astrojs/preact": "5.1.5",
    "@astrojs/sitemap": "3.7.3",
    "@astrojs/starlight": "0.39.3",
    "@astrojs/starlight-tailwind": "5.0.0",
    "@iconify-json/lucide": "^1.2.105",
    "@tailwindcss/vite": "^4.2.4",
    "astro": "6.4.4",
    "astro-icon": "^1.1.5",
    "astrojs-service-worker": "^2.0.0",
    "embla-carousel": "^8.6.0",
    "embla-carousel-autoplay": "^8.6.0",
    "github-buttons": "^2.32.0",
    "marked": "^18.0.2",
    "mermaid": "^11.15.0",
    "node-html-parser": "^7.1.0",
    "playwright": "^1.59.1",
    "preact": "^10.29.1",
    "rehype-external-links": "^3.0.0",
    "rehype-mermaid": "^3.0.0",
    "sharp": "^0.34.5",
    "starlight-links-validator": "^0.24.0",
    "starlight-sidebar-topics": "^0.7.1",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "baseline-browser-mapping": "^2.10.24",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": "26.x"
  }
}
