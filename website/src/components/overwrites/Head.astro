---
import {Font} from 'astro:assets';
const {head} = Astro.locals.starlightRoute;

const hasOgImage = head.some(
  ({tag, attrs}) => tag === 'meta' && attrs?.property === 'og:image',
);
const ogImageUrl = hasOgImage
  ? undefined
  : new URL('/og-distr.webp', Astro.site).href;
---

<Font cssVariable="--font-inter" preload />
<Font cssVariable="--font-poppins" preload />
{
  head.map(({tag: Tag, attrs, content}) =>
    content !== undefined && content !== null ? (
      <Tag {...attrs} set:html={content} />
    ) : (
      <Tag {...attrs} />
    ),
  )
}
{ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
