---
import LanguageSelect from '@astrojs/starlight/components/LanguageSelect.astro';
import Search from '@astrojs/starlight/components/Search.astro';
import SiteTitle from './SiteTitle.astro';
import SocialIcons from './SocialIcons.astro';
import ThemeSelect from './ThemeSelect.astro';
import GitHubStarButton from '~/components/common/GitHubStarButton.astro';
import MegaMenu from '~/components/navigation/MegaMenu.astro';
import {links} from '~/data/navigation';
import {megaMenuConfigs} from '~/data/megaMenuConfig';

const slug = Astro.locals.starlightRoute.entry.slug;
---

<div class="header sl-flex">
  <div class="sl-flex left-group">
    <SiteTitle />
    <div class="search-wrapper">
      <Search />
    </div>
  </div>
  <div class="sl-hidden lg:sl-flex nav-centered">
    <nav class="desktop" aria-label="Main navigation">
      {
        links.map((link) => {
          const megaMenuConfig = link.isMegaMenu && link.megaMenuType
            ? megaMenuConfigs[link.megaMenuType]
            : null;

          return (
          <div class="nav-item">
            {link.isMegaMenu && megaMenuConfig ? (
              <MegaMenu
                title={link.title}
                items={megaMenuConfig.items}
                columns={megaMenuConfig.columns}
                itemWidth={megaMenuConfig.itemWidth}
                href={link.value}
              />
            ) : link.children ? (
              <div class="dropdown">
                <button
                  class="dropdown-trigger"
                  type="button"
                  aria-haspopup="true"
                  aria-expanded="false"
                >
                  {link.title}
                  <svg
                    width="12"
                    height="12"
                    viewBox="0 0 12 12"
                    fill="currentColor"
                    aria-hidden="true"
                    style="display: inline-block; margin-left: 4px;"
                  >
                    <path d="M6 8L2 4h8z" />
                  </svg>
                </button>
                <div class="dropdown-content" role="menu">
                  {link.children.map((child) => (
                    <a href={child.value} class="dropdown-item" role="menuitem">
                      {child.title}
                    </a>
                  ))}
                </div>
              </div>
            ) : (
              <a href={link.value}>{link.title}</a>
            )}
          </div>
          );
        })
      }
    </nav>
  </div>
  <div class="sl-hidden lg:sl-flex right-group">
    <div class="github-star-wrapper">
      <GitHubStarButton repo="distr-sh/distr" />
    </div>
    <div class="sl-flex social-icons">
      <SocialIcons />
    </div>
  </div>

  <div class="sl-hidden md:sl-flex cta-buttons">
    <a
      href="https://cal.glasskube.com/team/gk/demo"
      target="_blank"
      class="no-underline text-sm inline-flex items-center justify-center px-3 py-1.5 font-medium bg-white dark:bg-transparent text-gray-900 dark:text-white hover:text-gray-900 dark:hover:text-white hover:bg-accent-600/10 dark:hover:bg-accent-200/10 border-2 border-accent-600 dark:border-accent-200 rounded-lg transition-colors focus:ring-4 focus:outline-none focus:ring-accent-600/20">
      Book Demo
    </a>
    <a
      href="/onboarding/"
      class="text-white hover:text-white no-underline text-sm bg-accent-600 hover:bg-accent-700 border-2 border-accent-600 focus:ring-4 focus:outline-none focus:ring-accent-600/20 font-medium rounded-lg px-3 py-1.5 text-center transition-colors">
      Start free trial
    </a>
    <a
      href="https://app.distr.sh"
      target="_blank"
      class="font-medium accent-current hover:underline">
      Login
    </a>
    <div class="theme-wrapper">
      <ThemeSelect />
    </div>
  </div>
</div>

<style>
  .header {
    gap: var(--sl-nav-gap);
    justify-content: space-between;
    align-items: center;
    height: 100%;
  }
  .left-group {
    gap: 1rem;
    align-items: center;
    flex: 0 0 auto;
  }
  .nav-centered {
    flex: 1;
    justify-content: center;
    align-items: center;
    padding-left: 9rem;
  }
  .right-group {
    gap: 1rem;
    align-items: center;
    flex: 0 0 auto;
    justify-content: flex-end;
  }
  .social-icons {
    gap: 1rem;
    align-items: center;
  }
  .cta-buttons {
    gap: 0.75rem;
    align-items: center;
  }
  .github-star-wrapper {
    padding-top: 0.5rem;
  }

  /* Responsive widths */
  @media (min-width: 72rem) and (max-width: 79.9375rem) {
    /* 1152px–1279px: Desktop nav + CTAs, no search/social/stars */
    .search-wrapper {
      display: none;
    }
    .social-icons {
      display: none;
    }
    .github-star-wrapper {
      display: none;
    }
  }

  @media (min-width: 80rem) and (max-width: 95.9375rem) {
    /* 1280px–1535px: Add search + social icons back, still no stars */
    .github-star-wrapper {
      display: none;
    }
  }

  @media (max-width: 72rem) {
    /* Mobile: no minimum width */
    .left-group {
      min-width: auto;
    }
    .right-group {
      min-width: auto;
    }
  }
  .release-link::after,
  .social-icons::before,
  .theme-wrapper::before {
    content: '';
    height: 2rem;
    border-inline-end: 1px solid var(--sl-color-gray-5);
  }
  .theme-wrapper {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  @media (min-width: 50rem) {
    :global(:root[data-has-sidebar]) {
      --__sidebar-pad: calc(2 * var(--sl-nav-pad-x));
    }
    :global(:root:not([data-has-toc])) {
      --__toc-width: 0rem;
    }
    .header {
      --__sidebar-width: max(
        0rem,
        var(--sl-content-inline-start, 0rem) - var(--sl-nav-pad-x)
      );
      --__main-column-fr: calc(
        (
            100% + var(--__sidebar-pad, 0rem) -
              var(--__toc-width, var(--sl-sidebar-width)) -
              (2 * var(--__toc-width, var(--sl-nav-pad-x))) -
              var(--sl-content-inline-start, 0rem) - var(--sl-content-width)
          ) /
          2
      );
      display: grid;
      /* 800px–1151px: left-group | nav (collapsed) | cta-buttons | right-group (hidden) */
      grid-template-columns: auto 1fr auto auto;
      align-content: center;
    }
  }

  @media (min-width: 72rem) and (max-width: 79.9375rem) {
    .header {
      grid-template-columns: auto 1fr auto auto;
    }
  }

  @media (min-width: 80rem) and (max-width: 95.9375rem) {
    .header {
      grid-template-columns: minmax(300px, auto) 1fr auto auto;
    }
  }

  @media (min-width: 96rem) {
    .header {
      grid-template-columns: minmax(400px, auto) 1fr auto auto;
    }
  }
  .desktop a:hover,
  .dropdown-trigger:hover {
    color: var(--sl-color-gray-2);
  }
  :root[data-theme='light'] {
    .desktop a:hover,
    .dropdown-trigger:hover {
      color: var(--sl-color-gray-3);
    }
  }
</style>
<style is:global>
  .header {
    border: none !important;
  }
  body[data-mobile-menu-expanded] header {
    background-color: var(--sl-color-bg);
  }
</style>

{
  /* prettier-ignore */
  !slug.startsWith('docs') && <>
    <style>
      .header {
        background-color: transparent;
        -webkit-backdrop-filter: blur(16px);
        backdrop-filter: blur(16px);
        padding-inline-end: calc(var(--sl-nav-gap) + var(--sl-nav-pad-x));
      }

      @media (min-width: 50rem) {
        header {
          background-color: transparent !important;
        }
      }
      @media (min-width: 50rem) {
        .header {
          padding-inline-end: var(--sl-nav-pad-y);
        }
      }
    </style>
  </>
}

<style>
  .desktop {
    display: none;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    padding-inline-end: 1rem;
  }
  @media (min-width: 72rem) {
    .desktop {
      display: flex;
    }
    .mobile {
      display: none;
    }
  }

  .nav-item {
    position: relative;
  }

  .desktop a {
    color: var(--sl-color-white);
    font-weight: 600;
    text-decoration: none;
  }

  .dropdown-trigger {
    background: none;
    border: none;
    color: var(--sl-color-white);
    font-weight: 600;
    font-size: inherit;
    font-family: inherit;
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
  }

  .dropdown-trigger:hover {
    color: var(--sl-color-gray-2);
  }

  :root[data-theme='light'] .dropdown-trigger:hover {
    color: var(--sl-color-gray-3);
  }

  .dropdown {
    position: relative;
  }

  .dropdown::before {
    content: '';
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    height: 0.5rem;
    background: transparent;
  }

  .dropdown-content {
    display: none;
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 0;
    background-color: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    padding: 0.5rem 0;
    min-width: 180px;
    z-index: 1000;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
  }

  .dropdown:hover .dropdown-content {
    display: block;
  }

  .dropdown-item {
    display: block;
    padding: 0.5rem 1rem;
    color: var(--sl-color-white);
    font-weight: 400;
    font-size: 0.9rem;
    text-decoration: none;
  }

  .dropdown-item:hover {
    background-color: var(--sl-color-gray-5);
    color: var(--sl-color-white);
  }

  :root[data-theme='light'] .dropdown-item {
    color: var(--sl-color-gray-1);
  }

  :root[data-theme='light'] .dropdown-item:hover {
    background-color: var(--sl-color-gray-6);
    color: var(--sl-color-gray-1);
  }

  /* From https://github.com/withastro/starlight/blob/main/packages/starlight/components/Select.astro */
  label {
    --sl-label-icon-size: 0.875rem;
    --sl-caret-size: 1.25rem;
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.25rem;
    color: var(--sl-color-gray-1);
  }

  label:hover {
    color: var(--sl-color-gray-2);
  }

  .icon {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
  }

  .label-icon {
    font-size: var(--sl-label-icon-size);
    inset-inline-start: 0;
  }

  .caret {
    font-size: var(--sl-caret-size);
    inset-inline-end: 0;
  }

  select {
    border: 0;
    padding-block: 0.625rem;
    padding-inline: calc(var(--sl-label-icon-size) + 0.25rem)
      calc(var(--sl-caret-size) + 0.25rem);
    width: var(--sl-select-width);
    background-color: transparent;
    text-overflow: ellipsis;
    color: inherit;
    cursor: pointer;
    appearance: none;
  }

  option {
    background-color: var(--sl-color-bg-nav);
    color: var(--sl-color-gray-1);
  }

  @media (min-width: 50rem) {
    select {
      font-size: var(--sl-text-sm);
    }
  }
</style>
