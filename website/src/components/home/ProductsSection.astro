---
import ThemedImage from '../util/ThemedImage.astro';
import SignupButton from '~/components/buttons/SignupButton.astro';
import {images} from '~/assets/index';

const products = [
  {
    title: 'Single pane of glass for every self-hosted customer',
    description:
      'Manage customers, releases, deployment targets, artifacts, entitlements, logs, health, and support workflows from one place.',
    lightImage: images.distr.dashboard.light,
    darkImage: images.distr.dashboard.dark,
    alt: 'Distr software distribution platform dashboard',
  },
  {
    title: 'A guided path for your customers',
    description:
      'Give customers one place to install, access artifacts, manage credentials, control versions, and stay on top of their deployments.',
    lightImage: images.distr.customerPortal.light,
    darkImage: images.distr.customerPortal.dark,
    alt: 'Distr customer portal for self-hosted deployments',
  },
  {
    title: 'Cut the support burden of self-hosted deployments',
    description:
      'Centralize customer versions, entitlements, logs, metrics, deployment status, and support bundles so support and engineering can diagnose issues without long back-and-forth cycles.',
    lightImage: images.distr.logViewer.light,
    darkImage: images.distr.logViewer.dark,
    alt: 'Distr log viewer for self-hosted customer deployments',
  },
];
---

<section class="py-8 md:py-16 lg:py-24 bg-gray-50 dark:bg-gray-800">
  <div class="container mx-auto px-4 max-w-7xl">
    <div class="text-center mb-12 md:mb-16 max-w-4xl mx-auto">
      <h2 class="text-2xl md:text-3xl lg:text-4xl font-bold leading-tight">
        The operational layer for self-hosted software
      </h2>
      <p class="mt-4 text-base md:text-lg text-gray-600 dark:text-gray-300">
        Keep onboarding, access, updates, observability, troubleshooting, and
        customer-facing workflows consistent across VPC, BYOC, on-prem,
        GovCloud, and air-gapped environments.
      </p>
    </div>

    {
      products.map(product => (
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 md:gap-8 lg:gap-12 mb-12 md:mb-16 lg:mb-20 items-start">
          <div class="lg:col-span-4 lg:sticky lg:top-24">
            <h3 class="text-xl md:text-2xl lg:text-3xl font-bold mb-3 md:mb-4 border-l-4 border-accent-600 pl-3 md:pl-4">
              {product.title}
            </h3>
            <p class="text-base md:text-lg text-gray-600 dark:text-gray-300 mb-4 md:mb-6 pl-3 md:pl-4 leading-relaxed">
              {product.description}
            </p>
            <div class="pl-3 md:pl-4">
              <SignupButton />
            </div>
          </div>
          <div class="lg:col-span-8">
            <div class="rounded-xl overflow-hidden shadow-[0_20px_60px_rgba(0,0,0,0.15)] bg-gray-100 dark:bg-gray-800 border border-gray-200 dark:border-gray-700">
              <ThemedImage
                lightSrc={product.lightImage}
                darkSrc={product.darkImage}
                alt={product.alt}
              />
            </div>
          </div>
        </div>
      ))
    }
  </div>
</section>
